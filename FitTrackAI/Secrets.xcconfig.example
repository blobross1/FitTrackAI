// 1. Copy to FitTrackAI/Secrets.xcconfig (same folder — Xcode links this file)
// 2. Fill in your values
// IMPORTANT: In .xcconfig, // is a comment — never write https:// directly. Use:
//   FITTRACK_API_URL = https:/$()/your-project.vercel.app/api/analyze

SUPERWALL_API_KEY = pk_YOUR_SUPERWALL_KEY

FITTRACK_API_URL = https:/$()/YOUR-PROJECT.vercel.app/api/analyze
FITTRACK_API_SECRET = your-long-random-secret-matching-vercel-env

BYPASS_PAYWALL = 1
